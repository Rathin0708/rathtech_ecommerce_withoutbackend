# ─── Sanity — Public (safe for client bundle) ────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# ─── Sanity — Server only (NEVER expose via NEXT_PUBLIC_ prefix) ─────────────
# Create a "Viewer" token at sanity.io/manage → Project → API → Tokens
SANITY_API_TOKEN=your_sanity_viewer_token_here
# Generate with: openssl rand -base64 32
SANITY_REVALIDATE_SECRET=generate_with__openssl_rand_base64_32

# ─── Site ─────────────────────────────────────────────────────────────────────
# Production URL — used in canonical tags, OG images, sitemap, robots.txt
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_STORE_NAME=Your Store Name

# ─── Analytics (optional) ─────────────────────────────────────────────────────
# Vercel Analytics + Speed Insights are enabled via the Vercel dashboard (no env var needed)
# Google Analytics 4 — optional, leave blank to disable
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
